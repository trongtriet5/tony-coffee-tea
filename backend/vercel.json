{
  "version": 2,
  "builds": [
    {
      "src": "src/main.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/products/(.*)",
      "headers": {
        "Cache-Control": "public, s-maxage=60, stale-while-revalidate=120"
      }
    },
    {
      "src": "/api/products/categories",
      "headers": {
        "Cache-Control": "public, s-maxage=60, stale-while-revalidate=120"
      }
    },
    {
      "src": "/api/products/toppings",
      "headers": {
        "Cache-Control": "public, s-maxage=60, stale-while-revalidate=120"
      }
    },
    {
      "src": "/(.*)",
      "dest": "src/main.ts"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-DNS-Prefetch-Control",
          "value": "on"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
